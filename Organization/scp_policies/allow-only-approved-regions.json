{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "DenyRegionsNotAllowed",
        "Effect": "Deny",
        "NotAction": [
          "iam:*",
          "sts:*",
          "organizations:*",
          "ram:*",
          "account:*",
          "budgets:*",
          "ce:*",
          "chatbot:*",
          "cloudfront:*",
          "globalaccelerator:*",
          "health:*",
          "route53:*",
          "route53domains:*",
          "route53resolver:*",
          "shield:*",
          "support:*",
          "trustedadvisor:*",
          "waf:*",
          "wafv2:*"
        ],
        "Resource": "*",
        "Condition": {
          "StringNotEquals": {
            "aws:RequestedRegion": [
              "us-west-2",
              "us-west-1",
              "us-east-1"
            ]
          }
        }
      }
    ]
  }
